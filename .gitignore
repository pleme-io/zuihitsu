# zuihitsu-dev — local-only authoring + cache state.
# The Hashnode response cache is keyed by blake3(query body); regenerate
# via `nix run .#fetch`. Drafts are unpublished personal work; once they're
# ready, they should be authored on Hashnode rather than committed here
# (the production sitegen never sees `drafts/` — only the dev daemon does).
.cache/
drafts/

# Helm dependency cache — regenerated by `helm dependency update`.
# Chart.lock IS committed (pins version); the downloaded chart tarballs
# under charts/ are not.
chart/zuihitsu/charts/

Cargo.build-spec.json
